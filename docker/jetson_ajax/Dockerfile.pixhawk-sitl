FROM debian:trixie-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        libstdc++6 \
        netcat-openbsd \
        procps \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace/pixhawk/firmware/ardupilot
COPY entrypoints/pixhawk-sitl.sh /usr/local/bin/pixhawk-sitl
RUN chmod +x /usr/local/bin/pixhawk-sitl

EXPOSE 5760/tcp
CMD ["/usr/local/bin/pixhawk-sitl"]
