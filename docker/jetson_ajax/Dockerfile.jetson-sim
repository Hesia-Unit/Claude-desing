FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        coreutils \
        file \
        iproute2 \
        jq \
        procps \
        python3 \
        python3-future \
        qemu-user-static \
        util-linux \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work
COPY entrypoints/smoke.sh /usr/local/bin/jetson-sim-smoke
RUN chmod +x /usr/local/bin/jetson-sim-smoke

CMD ["/usr/local/bin/jetson-sim-smoke"]
