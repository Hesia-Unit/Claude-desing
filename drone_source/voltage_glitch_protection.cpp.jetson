    start_voltage_glitch_monitoring();
}

bool VoltageGlitchProtection::is_monitoring_active() {
    return glitch_monitor_active.load();
}

bool VoltageGlitchProtection::is_voltage_sensor_available() {
    return voltage_sensor_available.load();
}

void VoltageGlitchProtection::implement_voltage_clamping() {
    implement_voltage_clamping_internal(); // Appeler la version interne
}

void VoltageGlitchProtection::setup_voltage_watchdog() {
    setup_voltage_watchdog_internal(); // Appeler la version interne
}

bool VoltageGlitchProtection::is_clamping_active() {
    return voltage_clamping_active.load();
}

void VoltageGlitchProtection::activate_clamping() {
    voltage_clamping_active = true;
}

void VoltageGlitchProtection::deactivate_clamping() {
    voltage_clamping_active = false;
}

bool VoltageGlitchProtection::is_watchdog_active() {
    return watchdog_active.load();
}

void VoltageGlitchProtection::activate_watchdog() {
    watchdog_active = true;
}

void VoltageGlitchProtection::deactivate_watchdog() {
    watchdog_active = false;
}

bool VoltageGlitchProtection::test_voltage_glitch_protection() {
    std::cout << "🧪 Test protection voltage glitch..." << std::endl;
    
    // Simuler un under-voltage
    VoltageGlitchSample glitch_sample;
    glitch_sample.voltage_v = nominal_voltage.load() * 0.5; // 50% du normal
    glitch_sample.duration_us = 100;
    glitch_sample.timestamp = std::chrono::duration_cast<std::chrono::nanoseconds>(
        std::chrono::high_resolution_clock::now().time_since_epoch()).count();
    glitch_sample.glitch_type = GLITCH_UNDER_VOLTAGE;
    glitch_sample.glitch_detected = false;
    
    bool detection_works = detect_under_voltage_glitch(glitch_sample);
    
    std::cout << "Test voltage glitch protection: " << (detection_works ? "✅ PASS" : "❌ FAIL") << std::endl;
    return detection_works;
}

VoltageGlitchProtection::VoltageGlitchStats VoltageGlitchProtection::get_voltage_glitch_statistics() {
    VoltageGlitchStats stats{};
    
    if (glitch_history.empty()) {
        return stats;
    }
    
    stats.total_samples = glitch_history.size();
    stats.glitch_count = glitch_count.load();
    stats.clamping_events = clamping_events.load();
    
    // Calculer les statistiques de voltage
    double total_voltage = 0.0;
    stats.min_voltage = glitch_history[0].voltage_v;
    stats.max_voltage = glitch_history[0].voltage_v;
    
    for (const auto& sample : glitch_history) {
        total_voltage += sample.voltage_v;
        
        if (sample.voltage_v < stats.min_voltage) {
            stats.min_voltage = sample.voltage_v;
        }
        if (sample.voltage_v > stats.max_voltage) {
            stats.max_voltage = sample.voltage_v;
        }
        
        // Compter les types de glitches
        switch (sample.glitch_type) {
            case GLITCH_UNDER_VOLTAGE:
                stats.under_voltage_glitches++;
                break;
            case GLITCH_OVER_VOLTAGE:
                stats.over_voltage_glitches++;
                break;
            case GLITCH_VOLTAGE_SPIKE:
                stats.voltage_spikes++;
                break;
            case GLITCH_VOLTAGE_DIP:
                stats.voltage_dips++;
                break;
            default:
                break;
        }
    }
    
    stats.avg_voltage = total_voltage / glitch_history.size();
    
    return stats;
}

void VoltageGlitchProtection::set_glitch_threshold(double threshold_percent) {
    glitch_threshold_percent = threshold_percent;
}

void VoltageGlitchProtection::set_clamping_threshold(uint32_t threshold_mv) {
    clamping_threshold_mv = threshold_mv;
}

void VoltageGlitchProtection::set_nominal_voltage(double nominal_voltage_v) {
    nominal_voltage = nominal_voltage_v;
}

void VoltageGlitchProtection::reset_voltage_glitch_statistics() {
    glitch_count = 0;
    clamping_events = 0;
    glitch_history.clear();
}

VoltageGlitchProtection::VoltageHealth VoltageGlitchProtection::get_voltage_health() {
    if (glitch_history.empty()) {
        return VOLTAGE_HEALTH_GOOD;
    }
    
    uint32_t recent_glitches = 0;
    size_t check_samples = std::min(glitch_history.size(), static_cast<size_t>(50));
    
    for (size_t i = glitch_history.size() - check_samples; i < glitch_history.size(); i++) {
        if (glitch_history[i].glitch_detected) {
            recent_glitches++;
        }
    }
    
    if (recent_glitches > 10) {
        return VOLTAGE_HEALTH_EMERGENCY;
    } else if (recent_glitches > 5) {
        return VOLTAGE_HEALTH_CRITICAL;
    } else if (recent_glitches > 1) {
        return VOLTAGE_HEALTH_WARNING;
    }
    
    return VOLTAGE_HEALTH_GOOD;
}

void VoltageGlitchProtection::set_voltage_sensor_path(const std::string& path) {
    voltage_sensor_path = path;
}

void VoltageGlitchProtection::set_clamping_status_path(const std::string& path) {
    clamping_status_path = path;
}

void VoltageGlitchProtection::set_watchdog_status_path(const std::string& path) {
    watchdog_status_path = path;
}

void VoltageGlitchProtection::cleanup() {
    stop_voltage_glitch_monitoring();
    glitch_history.clear();
    glitch_count = 0;
    clamping_events = 0;
    voltage_clamping_active = false;
    watchdog_active = false;
}

// ===== FONCTIONS UTILITAIRES =====

double VoltageGlitchProtection::calculate_voltage_risk(const VoltageGlitchSample& sample) {
    double nominal = nominal_voltage.load();
    double voltage_ratio = sample.voltage_v / nominal;
    
    // Calculer le risque basé sur le rapport de voltage
    if (voltage_ratio < 0.5) {
        return 1.0; // Risque maximum (under-voltage sévère)
    } else if (voltage_ratio > 1.5) {
        return 1.0; // Risque maximum (over-voltage sévère)
    } else if (voltage_ratio < 0.8 || voltage_ratio > 1.2) {
        return 0.8; // Risque élevé
    } else if (voltage_ratio < 0.9 || voltage_ratio > 1.1) {
        return 0.5; // Risque moyen
    } else {
        return 0.1; // Risque faible
    }
}

bool VoltageGlitchProtection::is_voltage_anomalous(double voltage) {
    if (!std::isfinite(voltage) || voltage <= 0.0) {
        return true;
    }
    double nominal = nominal_voltage.load();
    double threshold = nominal * (glitch_threshold_percent.load() / 100.0);
    
    double deviation = std::abs(voltage - nominal);
    return deviation > threshold;
}

void VoltageGlitchProtection::log_voltage_event(const std::string& event, const VoltageGlitchSample& sample) {
    std::ofstream log_file(voltage_log_path, std::ios::app);
    if (log_file.is_open()) {
        log_file << "[" << sample.timestamp << "] " << event
                << " - Voltage: " << sample.voltage_v << "V"
                << ", Duration: " << sample.duration_us << "μs"
                << ", Type: " << static_cast<int>(sample.glitch_type) << std::endl;
        log_file.close();
    }
}

} // namespace hesia
